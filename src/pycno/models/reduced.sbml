  <model id="mw54c37459_97d5_4373_8b50_013c4c27cf6a" name="simple_model">
    <listOfUnitDefinitions>
      <unitDefinition id="MWBUILTINUNIT_liter" name="liter">
        <listOfUnits>
          <unit kind="metre" exponent="3"/>
          <unit kind="dimensionless" multiplier="0.001"/>
        </listOfUnits>
      </unitDefinition>
      <unitDefinition id="MWBUILTINPREFIX_nano_MWBUILTINUNIT_mole" name="nanomole">
        <listOfUnits>
          <unit kind="mole" exponent="1" multiplier="1e-09"/>
        </listOfUnits>
      </unitDefinition>
      <unitDefinition id="MWDERIVEDUNIT_1__minute" name="1/minute">
        <listOfUnits>
          <unit kind="second" exponent="-1"/>
          <unit kind="dimensionless" multiplier="0.0166666666666667"/>
        </listOfUnits>
      </unitDefinition>
      <unitDefinition id="MWDERIVEDUNIT_liter__nanomole__minute" name="liter/nanomole/minute">
        <listOfUnits>
          <unit kind="metre" exponent="3"/>
          <unit kind="mole" exponent="-1"/>
          <unit kind="second" exponent="-1"/>
          <unit kind="dimensionless" multiplier="16666.6666666667"/>
        </listOfUnits>
      </unitDefinition>
      <unitDefinition id="MWDERIVEDUNIT_liter__minute" name="liter/minute">
        <listOfUnits>
          <unit kind="metre" exponent="3"/>
          <unit kind="second" exponent="-1"/>
          <unit kind="dimensionless" multiplier="1.66666666666667e-05"/>
        </listOfUnits>
      </unitDefinition>
      <unitDefinition id="MWDERIVEDUNIT_nanomole__liter" name="nanomole/liter">
        <listOfUnits>
          <unit kind="metre" exponent="-3"/>
          <unit kind="mole" exponent="1"/>
          <unit kind="dimensionless" multiplier="1e-06"/>
        </listOfUnits>
      </unitDefinition>
      <unitDefinition id="MWDERIVEDUNIT_meter___2" name="meter^2">
        <listOfUnits>
          <unit kind="metre" exponent="2"/>
          <unit kind="dimensionless" multiplier="1"/>
        </listOfUnits>
      </unitDefinition>
      <unitDefinition id="MWBUILTINPREFIX_centi_MWBUILTINUNIT_meter" name="centimeter">
        <listOfUnits>
          <unit kind="metre" exponent="1" multiplier="0.01"/>
        </listOfUnits>
      </unitDefinition>
      <unitDefinition id="MWBUILTINUNIT_minute" name="minute">
        <listOfUnits>
          <unit kind="second" exponent="1" multiplier="60"/>
        </listOfUnits>
      </unitDefinition>
      <unitDefinition id="MWBUILTINUNIT_meter" name="meter">
        <listOfUnits>
          <unit kind="metre" exponent="1" multiplier="1"/>
        </listOfUnits>
      </unitDefinition>
      <unitDefinition id="MWDERIVEDUNIT_liter__kilogram" name="liter/kilogram">
        <listOfUnits>
          <unit kind="gram" exponent="-1"/>
          <unit kind="metre" exponent="3"/>
          <unit kind="dimensionless" multiplier="1e-06"/>
        </listOfUnits>
      </unitDefinition>
    </listOfUnitDefinitions>
